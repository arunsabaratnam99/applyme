{
  "name": "applyme",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @applyme/web dev",
    "dev:api": "pnpm --filter @applyme/api dev",
    "dev:api:remote": "pnpm --filter @applyme/api dev:remote",
    "db:generate": "pnpm --filter @applyme/db generate",
    "db:migrate": "pnpm --filter @applyme/db migrate",
    "db:studio": "pnpm --filter @applyme/db studio",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md}\" --ignore-path .gitignore"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "prettier": "^3.2.5",
    "typescript": "^5.3.3",
    "vitest": "^1.3.1"
  }
}
