# ─── Web App (apps/web) ───────────────────────────────────────────────────────
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── API Worker (apps/api) ────────────────────────────────────────────────────

# Database (Neon serverless postgres, or local docker postgres for dev)
DATABASE_URL=postgresql://applyme:applyme@localhost:5432/applyme

# Cloudflare R2 (private bucket)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=applyme-resumes
R2_ENDPOINT=https://<account_id>.r2.cloudflarestorage.com

# VAPID keys for web push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# OAuth — Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# JWT signing secret (min 32 chars, random string)
JWT_SECRET=change-me-to-a-long-random-secret-string

# App base URL
APP_BASE_URL=http://localhost:3000

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Email via Resend (default: off)
EMAIL_ENABLED=false
RESEND_API_KEY=

# LinkedIn Jobs API (requires LinkedIn Partner API approval)
LINKEDIN_ENABLED=false
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# Indeed Publisher API (requires free Indeed Publisher account)
INDEED_ENABLED=false
INDEED_PUBLISHER_ID=

# USAJOBS (not used — replaced by Job Bank Canada)
# USAJOBS_API_KEY=

# ─── Observability ────────────────────────────────────────────────────────────

# Sentry (optional; if set, error tracking is enabled)
SENTRY_DSN=

# ─── Local Dev Storage (mock R2) ─────────────────────────────────────────────
# Set to "local" to use local filesystem storage instead of real R2
STORAGE_ADAPTER=local
LOCAL_STORAGE_PATH=./.local-storage
