# ─── Web App (apps/web) ───────────────────────────────────────────────────────
# Local dev: http://localhost:8787
# Production: https://applyme-api.<your-subdomain>.workers.dev
NEXT_PUBLIC_API_URL=http://localhost:8787
NEXT_PUBLIC_API_BASE_URL=http://localhost:8787
NEXT_PUBLIC_VAPID_PUBLIC_KEY=

# ─── API Worker (apps/api) ────────────────────────────────────────────────────

# Database (Neon serverless postgres, or local docker postgres for dev)
DATABASE_URL=postgresql://applyme:applyme@localhost:5432/applyme

# Object Storage — Google Cloud Storage (S3-compatible via HMAC keys)
# GCS: Endpoint = https://storage.googleapis.com, get HMAC keys from Cloud Storage > Settings > Interoperability
# Cloudflare R2: Endpoint = https://<account_id>.r2.cloudflarestorage.com
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=applyme-resumes
R2_ENDPOINT=https://storage.googleapis.com
R2_PUBLIC_URL=https://storage.googleapis.com/applyme-resumes

# VAPID keys for web push (generate with: npx web-push generate-vapid-keys)
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com

# OAuth — Google
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=

# OAuth — GitHub
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=

# JWT signing secret (min 32 chars, random string)
JWT_SECRET=change-me-to-a-long-random-secret-string

# App base URL
APP_BASE_URL=http://localhost:3000

# ─── Feature Flags ────────────────────────────────────────────────────────────

# Email via Resend (default: off)
EMAIL_ENABLED=false
RESEND_API_KEY=

# LinkedIn scraper (public guest job feed — no API approval needed)
LINKEDIN_SCRAPER_ENABLED=true

# Indeed scraper (public search pages — no Publisher account needed)
INDEED_SCRAPER_ENABLED=true

# USAJOBS (not used — replaced by Job Bank Canada)
# USAJOBS_API_KEY=

# ─── Observability ────────────────────────────────────────────────────────────

# Sentry (optional; if set, error tracking is enabled)
SENTRY_DSN=

# ─── Local Dev Storage (mock R2) ─────────────────────────────────────────────
# Set to "local" to use local filesystem storage instead of real R2
STORAGE_ADAPTER=local
LOCAL_STORAGE_PATH=./.local-storage
